# Секреты можно задать в .env или в GCP Secret Manager (проект playground-332710).
# В GCP: секреты gemini_api и main_SA (JSON ключа сервисного аккаунта).
# Локально нужен: gcloud auth application-default login (пользователь kirkademidov@gmail.com).

# Проект GCP для загрузки секретов (по умолчанию playground-332710)
# GCP_PROJECT_ID=playground-332710

# Gemini (или из секрета gemini_api)
# GEMINI_API_KEY=...

# Google Таблицы: ID таблицы и имя листа (main_SA — из GCP или файл)
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_SPREADSHEET_ID=1bsLE21JlwoXsve1g2GXnElhJZnNZRrCBj5-GE5_03lQ
GOOGLE_SHEET_NAME=Учителя

# WhatsApp Cloud API (PyWa) — для приёма сообщений по webhook
WA_PHONE_ID=
WA_TOKEN=
WA_CALLBACK_URL=https://your-public-url.ngrok.io
WA_VERIFY_TOKEN=any_random_string_for_verification
WA_APP_ID=
WA_APP_SECRET=
# Только эта группа (ID вида 120363...@g.us). Узнать: добавь бота в группу, смотри логи.
# WA_GROUP_ID=

# URL моста для веб-приложения (по умолчанию http://localhost:3080)
# BRIDGE_URL=http://localhost:3080

# GCS: экспорт истории чатов (одноразовый процесс — потом анализ берёт данные оттуда)
# Создайте бакет, выдайте сервисному аккаунту (main_SA) права Storage Object Admin на бакет.
# GCS_BUCKET=your-bucket-name
# GCS_EXPORT_PREFIX=wa-export/latest

# Логирование: уровень (DEBUG, INFO, WARNING, ERROR) и опционально файл
LOG_LEVEL=INFO
# LOG_PATH=logs/app.log

# Несколько пользователей: каждый видит только свои группы (логин + «мои группы»)
# AUTH_ENABLED=1
# APP_SECRET_KEY=случайная_строка_для_подписи_сессий
# AUTH_USERS_FILE=data/users.json
# Создать пользователя: uv run python scripts/create_user.py USERNAME PASSWORD
